###############################
### User-Owned Input Only   ###
###############################
# `make init-platform` reads this file, generates any runtime-only values into
# `.env.runtime`, and mounts the host SSH keys into the provisioning container.

################
###  Vault   ###
################
VAULT_ADDR=https://vault.ryuugu.dev
VAULT_TOKEN=

################
### Storage  ###
################
HOST_DATA_PATH=/srv/homelab

################
###  SSH     ###
################
HOST_GIT_PROVISIONING_KEY_FILE=/home/archusr/.ssh/git_provisioning_key
HOST_PROVISIONING_KEY_FILE=/home/archusr/.ssh/provisioning_key
HOST_DROPLET_KEY_FILE=/home/archusr/.ssh/id_droplet

################
### Git Repos ##
################
GIT_PROVISIONING_API_REPO=git@github.com:asdf57/prov2.git
GIT_PROV_CONTROLLER_REPO=git@github.com:asdf57/prov-controller-test.git
GIT_WEBHOOK_REPO=git@github.com:asdf57/webhook-server.git
GIT_INVENTORY_REPO=git@github.com:asdf57/inventory.git
GIT_GROUPVARS_REPO=git@github.com:asdf57/groupvars.git
GIT_ANSIBLE_ROLES_REPO=git@github.com:asdf57/ansible-roles.git
GIT_HOSTVARS_REPO=git@github.com:asdf57/hostvars.git
GIT_TEMPLATES_REPO=git@github.com:asdf57/homelab-templates.git
GIT_PROVISIONING_API_BRANCH=main
GIT_PROV_CONTROLLER_BRANCH=main
GIT_WEBHOOK_BRANCH=main
GIT_INVENTORY_BRANCH=main
GIT_GROUPVARS_BRANCH=main
GIT_ANSIBLE_ROLES_BRANCH=main
GIT_HOSTVARS_BRANCH=main
GIT_TEMPLATES_BRANCH=main
GROUPVARS_GIT_USER_NAME="Homelab Provisioner"
GROUPVARS_GIT_USER_EMAIL=homelab-provisioner@localhost
PRIMARY_ROUTER_NAME=mikrotik-1
PROVISIONING_API_IPV4=10.0.2.2

################
### Network  ###
################
NETWORK_DRIVER=macvlan
IPVLAN_SUBNET=10.0.2.0/24
IPVLAN_GATEWAY=10.0.2.1
IPVLAN_MODE=l2
MACVLAN_SUBNET=10.0.2.0/24
MACVLAN_GATEWAY=10.0.2.1
MACVLAN_HOST_IP=10.0.2.173/24
MACVLAN_MODE=bridge

################
### Concourse ##
################
CONCOURSE_VERSION=7.12.1
CONCOURSE_IPV4=10.0.2.126
CONCOURSE_DB_IPV4=10.0.2.127
CONCOURSE_URL=http://10.0.2.126:8080
CONCOURSE_USER=test
CONCOURSE_PASSWORD=test
CONCOURSE_TARGET=test
CONCOURSE_TEAM=main
CONCOURSE_COMMANDS_PIPELINE=commands
CONCOURSE_COMMANDS_RESOURCE=commands
CONCOURSE_OAUTH_CLIENT_ID=fly
CONCOURSE_OAUTH_CLIENT_SECRET=

################
### Cloudflare #
################
CLOUDFLARE_DOMAIN=ryuugu.dev
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=

################
### Certs     ##
################
CERT_AUTHORITY=zerossl
ZEROSSL_EMAIL=
ZEROSSL_EAB_KID=
ZEROSSL_EAB_HMAC_KEY=

################
### Postgres ###
################
POSTGRES_PASSWORD=

################
### Services ###
################
NGINX_IPV4=10.0.2.123
NGINX_ACME_LABEL=nginx.ryuugu.dev
SERVER_API_IPV4=10.0.2.124
SERVER_API_FQDN=server-api.ryuugu.dev
MGMT_FQDN=mgmt.ryuugu.dev
VAULT_IPV4=10.0.2.125
VAULT_URL=https://vault.ryuugu.dev
VAULT_ACME_LABEL=vault.ryuugu.dev
VAULT_API_FQDN=vault-api.ryuugu.dev
CONCOURSE_FQDN=ci.ryuugu.dev
REGISTRY_FQDN=registry.ryuugu.dev
REGISTRY_IPV4=10.0.2.122
WEBHOOK_IPV4=10.0.2.128
PROV_CONTROLLER_IPV4=10.0.2.129
PROV_CONTROLLER_FQDN=controller.ryuugu.dev
